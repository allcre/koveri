# Frontend Supabase configuration
# Copy this file to .env for local development.
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Server-side secrets are configured in Supabase, not in this frontend .env file:
# - YELLOWCAKE_API_KEY powers supabase/functions/yellowcake-proxy
# - LOVABLE_API_KEY powers supabase/functions/coach-chat and generate-profile
